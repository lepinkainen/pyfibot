{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "$id": "https://pyfibot.org/config-schema.json",
    "title": "PyFiBot Configuration Schema",
    "description": "Schema for PyFiBot configuration files",
    "type": "object",
    "required": ["networks"],
    "properties": {
        "admins": {
            "type": "array",
            "description": "List of admin users (nick!user@host format)",
            "items": {
                "type": "string",
                "pattern": "^.+!.+@.+$"
            }
        },
        "nick": {
            "type": "string",
            "description": "Default nickname for the bot"
        },
        "logging": {
            "type": "object",
            "description": "Logging configuration",
            "properties": {
                "debug": {
                    "type": "boolean",
                    "description": "Enable debug logging"
                }
            },
            "additionalProperties": false
        },
        "module_urltitle": {
            "type": "object",
            "description": "URL title module configuration",
            "properties": {
                "ignore_urls": {
                    "type": "array",
                    "description": "List of URL patterns to ignore",
                    "items": {
                        "type": "string"
                    }
                },
                "ignore_users": {
                    "type": "array",
                    "description": "List of users to ignore for URL title fetching",
                    "items": {
                        "type": "string"
                    }
                },
                "youtube_apikey": {
                    "type": "string",
                    "description": "YouTube Data API key"
                },
                "check_redundant": {
                    "type": "boolean",
                    "description": "Check for redundant URL titles"
                },
                "disable": {
                    "type": "string",
                    "description": "Comma-separated channel names to disable URL title fetching in"
                },
                "ignore": {
                    "type": "array",
                    "description": "List of patterns to ignore",
                    "items": {
                        "type": "string"
                    }
                },
                "lambda_enable": {
                    "type": "boolean",
                    "description": "Enable AWS Lambda-based URL fetching"
                },
                "lambda_url": {
                    "type": "string",
                    "description": "AWS Lambda function URL"
                },
                "lambda_apikey": {
                    "type": "string",
                    "description": "AWS Lambda API key"
                },
                "twitter_bearer": {
                    "type": "string",
                    "description": "Twitter/X API bearer token"
                },
                "areena": {
                    "type": "object",
                    "description": "Yle Areena API credentials",
                    "properties": {
                        "app_id": {
                            "type": "string",
                            "description": "Areena application ID"
                        },
                        "app_key": {
                            "type": "string",
                            "description": "Areena application key"
                        }
                    },
                    "additionalProperties": false
                },
                "ebay_appid": {
                    "type": "string",
                    "description": "eBay application ID"
                },
                "ebay_siteid": {
                    "type": "integer",
                    "description": "eBay site ID"
                },
                "ebay_currency": {
                    "type": "string",
                    "description": "eBay currency symbol"
                }
            },
            "additionalProperties": false
        },
        "module_wolfram_alpha": {
            "type": "object",
            "description": "Wolfram Alpha module configuration",
            "properties": {
                "appid": {
                    "type": "string",
                    "description": "Wolfram Alpha application ID"
                }
            },
            "additionalProperties": false
        },
        "networks": {
            "type": "object",
            "description": "Network configurations",
            "patternProperties": {
                "^[a-zA-Z0-9_-]+$": {
                    "type": "object",
                    "required": ["server"],
                    "properties": {
                        "server": {
                            "type": "string",
                            "description": "IRC server hostname"
                        },
                        "port": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 65535,
                            "default": 6667,
                            "description": "IRC server port"
                        },
                        "ssl": {
                            "type": "boolean",
                            "default": false,
                            "description": "Use SSL connection"
                        },
                        "channels": {
                            "type": "array",
                            "description": "List of channels to join",
                            "items": {
                                "type": "string",
                                "pattern": "^#.+"
                            }
                        },
                        "nickname": {
                            "type": "string",
                            "description": "Nickname for this network"
                        },
                        "password": {
                            "type": "string",
                            "description": "Server password"
                        },
                        "authname": {
                            "type": "string",
                            "description": "Authentication username"
                        },
                        "authpass": {
                            "type": "string",
                            "description": "Authentication password"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": true
}